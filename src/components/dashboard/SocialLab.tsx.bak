import { CAMPAIGN_ZERO_DATA } from '@/constants/DemoCampaignZero';

const sleep = (ms: number) => new Promise(resolve => setTimeout(resolve, ms));

let currentAudio: HTMLAudioElement | null = null;
let currentTimeout: NodeJS.Timeout | null = null;

const stopCurrentAudio = () => {
  if (currentAudio) {
    currentAudio.pause();
    currentAudio.currentTime = 0;
    currentAudio = null;
  }
  if (currentTimeout) {
    clearTimeout(currentTimeout);
    currentTimeout = null;
  }
};

const playSupabaseAudio = (fileName: string, abortSignal?: { aborted: boolean }): Promise<void> => {
  return new Promise((resolve) => {
    if (abortSignal?.aborted) {
      resolve();
      return;
    }

    const baseUrl = "https://njhifpbnrbbhbmwgedtz.supabase.co/storage/v1/object/public/system-audio/";
    const premiumFileName = fileName.includes('_premium') 
      ? fileName 
      : fileName.replace('.mp3', '_premium.mp3');
    const timestamp = new Date().getTime();
    
    currentTimeout = setTimeout(() => {
      console.log(`[Audio Timeout] ${premiumFileName} - continuando...`);
      currentAudio = null;
      currentTimeout = null;
      resolve();
    }, 15000);

    try {
      const audio = new Audio(`${baseUrl}${premiumFileName}?t=${timestamp}`);
      audio.volume = 0.8;
      currentAudio = audio;
      
      audio.onended = () => {
        if (currentTimeout) {
          clearTimeout(currentTimeout);
          currentTimeout = null;
        }
        currentAudio = null;
        console.log(`✅ Audio terminado: ${premiumFileName}`);
        resolve();
      };
      
      audio.onerror = () => {
        if (currentTimeout) {
          clearTimeout(currentTimeout);
          currentTimeout = null;
        }
        currentAudio = null;
        console.warn(`[Audio Error] ${premiumFileName}`);
        resolve();
      };
      
      audio.play().then(() => {
        console.log(`▶ Reproduciendo: ${premiumFileName}`);
      }).catch((err) => {
        if (currentTimeout) {
          clearTimeout(currentTimeout);
          currentTimeout = null;
        }
        currentAudio = null;
        console.warn(`[Audio Silenciado] No se pudo reproducir ${premiumFileName}:`, err);
        resolve();
      });
    } catch (error) {
      if (currentTimeout) {
        clearTimeout(currentTimeout);
        currentTimeout = null;
      }
      currentAudio = null;
      console.warn("[Audio Silenciado] Error al instanciar Audio:", error);
      resolve();
    }
  });
};

