          'social_video_reel', 'social_video_feed', 'social_video_story',
          'social_image_post', 'social_image_story', 'social_image_banner'
        ]);
        
      if (data) {
        const loadedAssets: Record<string, string> = {};
        data.forEach(item => loadedAssets[item.id] = item.url);
        setAssets(loadedAssets);
        
        const reelAsset = data.find(item => item.id === 'social_video_reel');
        if (reelAsset?.url) {
          setRealVideoUrl(reelAsset.url);
          console.log('📥 Fetched realVideoUrl from Supabase:', reelAsset.url);
        }
      }
      setLoading(false);
    };
    fetchAssets();
  }, []);

  const handleFileUpload = async (event: React.ChangeEvent<HTMLInputElement>) => {
    const file = event.target.files?.[0];
    if (!file) return;

    setUploading(true);
    try {
      const fileExt = file.name.split('.').pop();
      const fileName = `social_video_reel-${Date.now()}.${fileExt}`;

      const { error: uploadError } = await supabase.storage
        .from('visual-assets')
        .upload(fileName, file, { cacheControl: '3600', upsert: true });

      if (uploadError) throw uploadError;

      const { data: { publicUrl } } = supabase.storage
        .from('visual-assets')
        .getPublicUrl(fileName);

      const { error: dbError } = await supabase
        .from('visual_assets')
        .upsert({ id: 'social_video_reel', url: publicUrl, updated_at: new Date() });

      if (dbError) throw dbError;

